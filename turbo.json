{
  "$schema": "https://turborepo.dev/schema.json",
  "globalPassThroughEnv": ["VITE_API_BASE", "VITE_API_PATH"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".vite/**"],
      "env": ["VITE_API_BASE", "VITE_API_PATH"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
